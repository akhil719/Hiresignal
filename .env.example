# ── Required ──────────────────────────────────────────
# No required variables for basic operation (SQLite used by default)

# ── Optional: AI enrichment (Bonus layer) ─────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: Database ────────────────────────────────
# Defaults to SQLite (./hiring_intel.db) — swap for Postgres on deploy
# DATABASE_URL=postgresql://user:password@host:5432/hiring_intel

# ── Optional: Pipeline tuning ─────────────────────────
# How often to auto-scrape (hours). Default: 6
SCRAPE_INTERVAL_HOURS=6

# Surge detection multiplier. Default: 2.5 (flag if 2.5x normal volume)
SURGE_MULTIPLIER=2.5

# ── Optional: Server ──────────────────────────────────
PORT=8000
ENV=development   # set to "production" to disable auto-reload
